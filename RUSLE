// =================================================================
// RUSLE CON LÓGICA CONDICIONAL PARA K (2005- vs 2006+)
// Adaptado para: Zona de estudio UTM 19S
// =================================================================

// --- 0. CONFIGURACIÓN INICIAL ---

// TU ÁREA DE ESTUDIO (UTM 19S)
var aoi = ee.FeatureCollection('projects/ee-lilianvara4/assets/Zona_de_estudio_para_erosion_GEE_19S');

// CONFIGURACIÓN DE FECHA (AJUSTA SEGÚN NECESITES)
var añoAnalisis = 2005; // <-- CAMBIA AQUÍ: 2005, 2006, 2024, etc.

// CONFIGURACIÓN PARA FACTOR R (20 años previos al análisis)
var añosRetrocesoR = 20;
var fechaInicio_R = (añoAnalisis - añosRetrocesoR) + '-01-01'; // Ej: 1985-01-01 para 2005
var fechaFin_R = (añoAnalisis - 1) + '-12-31'; // Hasta el año anterior

// CONFIGURACIÓN PARA FACTOR C (temporada seca del año de análisis)
var fechaInicio_C = añoAnalisis + '-05-01';
var fechaFin_C = añoAnalisis + '-09-30';

// SISTEMA DE COORDENADAS (UTM 19S - igual que tus datos)
var CRS = 'EPSG:32719';
var ESCALA = 255; // Resolución de tus datos

// Centramos el mapa
Map.centerObject(aoi, 10);
Map.addLayer(aoi, {color: 'black', strokeWidth: 2, fillColor: '00000000'}, 'Área de Estudio ' + añoAnalisis);

// --- 1. FACTOR R (Erosividad de la lluvia) ---

var chirps = ee.ImageCollection('UCSB-CHG/CHIRPS/DAILY')
             .filter(ee.Filter.date(fechaInicio_R, fechaFin_R));

// Calcula Precipitación Media Anual (P)
var anios = ee.List.sequence(ee.Date(fechaInicio_R).get('year'), ee.Date(fechaFin_R).get('year'));
var precipAnual = ee.ImageCollection.fromImages(
  anios.map(function(y) {
    var annual = chirps.filter(ee.Filter.calendarRange(y, y, 'year')).sum();
    return annual.set('year', y);
  })
);
var P = precipAnual.mean().rename('P_anual');

// Calcula Precipitación Media Mensual (pi)
var meses = ee.List.sequence(1, 12);
var pi_collection = ee.ImageCollection.fromImages(
  meses.map(function(m) {
    var totalMonthlyCollection = ee.ImageCollection.fromImages(
        anios.map(function(y) {
            var monthlySum = chirps.filter(ee.Filter.calendarRange(y, y, 'year'))
                                   .filter(ee.Filter.calendarRange(m, m, 'month'))
                                   .sum();
            return monthlySum.set('year', y);
        })
    );
    return totalMonthlyCollection.mean().rename('pi').set('month', m);
  })
);

// Aplica fórmula de Arnoldus
var monthly_R_values = pi_collection.map(function(pi_image) {
  var term_log = pi_image.pow(2).divide(P);
  var exponent = ee.Image(1.5)
                   .multiply(term_log.add(1e-9).log10())
                   .subtract(0.08188);
  var monthly_R = ee.Image(1.735).multiply(ee.Image(10).pow(exponent));
  return monthly_R;
});

var R_Factor = monthly_R_values.sum().rename('R');

// --- 2. FACTOR K (LÓGICA CONDICIONAL: 2005 vs 2006+) ---

// FUNCIÓN PARA CALCULAR K DE SOILGRIDS (como en tu segundo código)
function calcularK_SoilGrids() {
  // Extraer las propiedades del suelo de SoilGrids
  var sand = ee.Image("projects/soilgrids-isric/sand_mean")
    .select('sand_0-5cm_mean')
    .divide(10.0);
    
  var silt = ee.Image("projects/soilgrids-isric/silt_mean")
    .select('silt_0-5cm_mean')
    .divide(10.0);
    
  var clay = ee.Image("projects/soilgrids-isric/clay_mean")
    .select('clay_0-5cm_mean')
    .divide(10.0);
    
  var orgC = ee.Image("projects/soilgrids-isric/soc_mean")
    .select('soc_0-5cm_mean')
    .divide(100.0);

  // Cálculos intermedios (fórmula de RUSLE para K)
  var fcl_si = silt.divide(clay.add(silt)).pow(0.3);
  
  var forgc = ee.Image(1).subtract(
    ee.Image(0.25).multiply(orgC).divide(
      orgC.add(ee.Image(3.72).subtract(ee.Image(2.95).multiply(orgC)).exp())
    )
  );
  
  var fcsand = ee.Image(0.2).add(
    ee.Image(0.3).multiply(
      ee.Image(-0.0256).multiply(sand).multiply(ee.Image(1).subtract(silt.divide(100))).exp()
    )
  );
  
  var term_hisand = ee.Image(1).subtract(sand.divide(100));
  
  var fhisand = ee.Image(1).subtract(
    ee.Image(0.7).multiply(term_hisand).divide(
      term_hisand.add(ee.Image(-5.51).add(ee.Image(22.9).multiply(term_hisand)).exp())
    )
  );

  // Factor K final
  var K_soilgrids = ee.Image(0.1317)
    .multiply(fcsand)
    .multiply(fcl_si)
    .multiply(forgc)
    .multiply(fhisand)
    .rename('K_soilgrids');
    
  return K_soilgrids;
}

// DECISIÓN: ¿SoilGrids o K personalizado?
var K_Factor;

if (añoAnalisis <= 2005) {
  // Para 2005 o antes: usar SoilGrids (sin minería)
  print('Usando SoilGrids para K (año ' + añoAnalisis + ' - sin minería)');
  
  var K_soilgrids = calcularK_SoilGrids();
  
  // Preparar y ajustar K de SoilGrids
  K_Factor = K_soilgrids
    .reproject({crs: CRS, scale: ESCALA})
    .clip(aoi)
    .updateMask(K_soilgrids.gt(0))
    .where(K_soilgrids.lt(0.001), 0.001)
    .where(K_soilgrids.gt(0.15), 0.15)
    .rename('K');
    
} else {
  // Para 2006 en adelante: usar tu K personalizado (con minería)
  print('Usando K personalizado para año ' + añoAnalisis + ' (con minería)');
  
  var K_raw = ee.Image('projects/ee-lilianvara4/assets/factor_k_sin_cauce_GEE_19S');
  
  // Limpieza y preparación de TU K personalizado
  K_Factor = K_raw
    .updateMask(K_raw.gt(0))
    .where(K_raw.lt(0.001), 0.001)
    .where(K_raw.gt(0.15), 0.15)
    .reproject({crs: CRS, scale: ESCALA})
    .clip(aoi)
    .rename('K');
}

